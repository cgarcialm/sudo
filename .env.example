# Required
ANTHROPIC_API_KEY=your_key_here

# Display (Pi only — set to :0 for the local screen)
DISPLAY=:0

# Screen (default: fullscreen at native resolution on Pi)
# Set to "false" on Mac/dev to run in a window
SCREEN_FULLSCREEN=true

# Expression loop interval in seconds (default: 15)
EXPRESSION_INTERVAL_SECONDS=15

# Gallery — save every rendered SVG to memory/gallery/ (default: off)
GALLERY_ENABLED=false

# Logging — set to DEBUG for verbose output (default: WARNING)
# LOG_LEVEL=DEBUG
